<!doctype html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Steubenville Florida Youth Conference &mdash; <%= t('app_title') %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
  <style>
    .conference-hero {
      position: relative;
      overflow: hidden;
      border-radius: 18px;
      padding: 2rem;
      background:
        linear-gradient(135deg, rgba(26,39,68,0.96), rgba(46,68,128,0.92)),
        radial-gradient(circle at top right, rgba(232,184,75,0.24), transparent 45%);
      color: #fff;
    }
    .conference-hero h1 {
      color: #fff;
      margin-bottom: 0.35rem;
    }
    .conference-eyebrow {
      display: inline-block;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--gold-light);
      margin-bottom: 0.75rem;
    }
    .conference-date {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      border: 1px solid rgba(255,255,255,0.18);
      border-radius: 999px;
      padding: 0.35rem 0.8rem;
      font-size: 0.84rem;
      color: rgba(255,255,255,0.86);
      background: rgba(255,255,255,0.08);
      margin-bottom: 1rem;
    }
    .conference-subtitle {
      max-width: 700px;
      color: rgba(255,255,255,0.82);
      font-size: 0.98rem;
      margin-bottom: 1.25rem;
    }
    .conference-stat-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 0.85rem;
      margin-top: 1.25rem;
    }
    .conference-stat {
      border: 1px solid rgba(255,255,255,0.14);
      border-radius: 12px;
      padding: 0.9rem 1rem;
      background: rgba(255,255,255,0.08);
    }
    .conference-stat strong {
      display: block;
      color: #fff;
      font-size: 1rem;
      margin-bottom: 0.1rem;
    }
    .conference-stat span {
      color: rgba(255,255,255,0.72);
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
    .conference-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 0.7rem;
    }
    .conference-list li {
      padding-left: 1.25rem;
      position: relative;
    }
    .conference-list li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0.65rem;
      width: 0.5rem;
      height: 0.5rem;
      border-radius: 50%;
      background: var(--gold);
      box-shadow: 0 0 0 4px rgba(232,184,75,0.18);
    }
    .itinerary-item + .itinerary-item {
      margin-top: 1rem;
      padding-top: 1rem;
      border-top: 1px solid var(--border);
    }
    .itinerary-day {
      font-size: 0.73rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--blue-sky);
      margin-bottom: 0.35rem;
    }
    .cta-panel {
      background: linear-gradient(180deg, var(--gold-pale), #fff8e9);
      border: 1px solid #f0d090;
      border-radius: 14px;
      padding: 1.4rem;
    }
  </style>
</head>
<body>
<%- include('_topbar') %>

<main class="container py-4 app-shell mx-auto">
  <div class="conference-hero mb-4">
    <div class="conference-eyebrow">Saint Matthew Youth Ministry</div>
    <h1>Steubenville Florida Youth Conference</h1>
    <div class="conference-date">June 18-21, 2026</div>
    <p class="conference-subtitle">
      A Saint Matthew conference page modeled after the Steubenville Florida event format, with space for parish-specific trip details, registration steps, and parent communication.
    </p>
    <div class="d-flex flex-wrap gap-2">
      <% if (user) { %>
        <a class="btn btn-primary" href="/dashboard">Open Dashboard</a>
      <% } else { %>
        <a class="btn btn-primary" href="/signup">Create Account</a>
        <a class="btn btn-outline-light" href="/login">Login</a>
      <% } %>
      <a class="btn btn-outline-light" href="https://steubenvilleconferences.com/events/florida/" target="_blank" rel="noreferrer">Conference Website</a>
    </div>
    <div class="conference-stat-grid">
      <div class="conference-stat">
        <strong>High School</strong>
        <span>Rising freshmen to seniors</span>
      </div>
      <div class="conference-stat">
        <strong>Orlando, FL</strong>
        <span>Rosen Shingle Creek</span>
      </div>
      <div class="conference-stat">
        <strong>4 Days</strong>
        <span>Prayer, talks, worship, fellowship</span>
      </div>
      <div class="conference-stat">
        <strong>St. Matthew Group</strong>
        <span>Parish trip information</span>
      </div>
    </div>
  </div>

  <div class="row g-4">
    <div class="col-lg-7">
      <div class="page-card h-100">
        <div class="card-header"><h2 class="h5">What This Trip Includes</h2></div>
        <div class="card-body">
          <ul class="conference-list">
            <li>Conference admission and parish group coordination.</li>
            <li>Hotel stay with youth chaperone supervision and room assignments.</li>
            <li>Meals, snacks, and daily group check-ins.</li>
            <li>Transportation details determined by Saint Matthew leadership.</li>
            <li>Group materials such as shirts, schedules, and trip communication.</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="col-lg-5">
      <div class="page-card h-100">
        <div class="card-header"><h2 class="h5">Who Should Attend</h2></div>
        <div class="card-body">
          <p class="mb-3">
            This page is intended for Saint Matthew teens who want a powerful summer conference experience centered on Jesus Christ, the sacraments, prayer, and Catholic community.
          </p>
          <p class="mb-0">
            Typical Steubenville weekends include keynote talks, praise and worship, Eucharistic adoration, reconciliation opportunities, small-group discussion, and time together as a parish group.
          </p>
        </div>
      </div>
    </div>

    <div class="col-lg-7">
      <div class="page-card">
        <div class="card-header"><h2 class="h5">Trip Itinerary</h2></div>
        <div class="card-body">
          <div class="itinerary-item">
            <div class="itinerary-day">Thursday, June 18</div>
            <div class="fw-semibold">Departure and group arrival</div>
            <p class="mb-0 text-muted">Travel from Saint Matthew, group check-in, orientation, and an opening community activity.</p>
          </div>
          <div class="itinerary-item">
            <div class="itinerary-day">Friday, June 19</div>
            <div class="fw-semibold">Conference Day One</div>
            <p class="mb-0 text-muted">Main sessions, worship, parish group conversation, and evening conference activities.</p>
          </div>
          <div class="itinerary-item">
            <div class="itinerary-day">Saturday, June 20</div>
            <div class="fw-semibold">Conference Day Two</div>
            <p class="mb-0 text-muted">Full-day conference experience with prayer, formation, sacraments, and community time.</p>
          </div>
          <div class="itinerary-item">
            <div class="itinerary-day">Sunday, June 21</div>
            <div class="fw-semibold">Closing session and return home</div>
            <p class="mb-0 text-muted">Final conference moments, parish regroup, and travel back to Saint Matthew.</p>
          </div>
        </div>
      </div>
    </div>

    <div class="col-lg-5">
      <div class="page-card">
        <div class="card-header"><h2 class="h5">Conference Location</h2></div>
        <div class="card-body">
          <p class="fw-semibold mb-1">Rosen Shingle Creek</p>
          <p class="text-muted mb-3">9939 Universal Blvd., Orlando, Florida 32819</p>
          <div class="d-flex flex-column gap-2">
            <a class="btn btn-outline-primary" href="https://www.rosenshinglecreek.com/" target="_blank" rel="noreferrer">Hotel Website</a>
            <a class="btn btn-outline-primary" href="https://steubenvilleconferences.com/events/florida/" target="_blank" rel="noreferrer">Official Conference Info</a>
          </div>
        </div>
      </div>
    </div>

    <div class="col-12">
      <div class="cta-panel">
        <h2 class="h5 mb-2">Saint Matthew Registration Notes</h2>
        <p class="mb-3">
          This page is ready to use as a Saint Matthew event page. You can update the trip cost, deposit process, number of available spots, parish contact person, waiver instructions, and transportation notes once your parish details are finalized.
        </p>
        <div class="d-flex flex-wrap gap-2">
          <% if (user) { %>
            <a class="btn btn-primary" href="/dashboard">Continue in Dashboard</a>
          <% } else { %>
            <a class="btn btn-primary" href="/signup">Create Account</a>
            <a class="btn btn-outline-secondary" href="/login">Login</a>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <p class="footer-note">Conference details, pricing, and deposit instructions should be confirmed by the Saint Matthew parish office before publishing to families.</p>
</main>
</body>
</html>

<!doctype html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= t('login') %> &mdash; <%= t('app_title') %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Hedvig+Letters+Serif:opsz@12..24&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body>

<%- include('_topbar') %>

<main class="container py-5 app-shell mx-auto">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-5">

      <div style="text-align:center;margin-bottom:1.5rem">
        <span style="font-size:2.5rem;color:var(--gold)">✦</span>
        <h1 style="font-family:'Hedvig Letters Serif',Georgia,serif;font-size:2rem;margin:.25rem 0 0"><%= t('login') %></h1>
      </div>

      <div class="page-card">
        <div class="card-body p-4">
          <% if (error.length) { %><div class="alert alert-danger"><%= error[0] %></div><% } %>
          <% if (success.length) { %><div class="alert alert-success"><%= success[0] %></div><% } %>

          <form method="post" action="/login" class="d-grid gap-3">
            <div>
              <label class="form-label"><%= t('email') %></label>
              <input class="form-control" type="email" name="email" autocomplete="email" required>
            </div>
            <div>
              <label class="form-label"><%= t('password') %></label>
              <input class="form-control" type="password" name="password" autocomplete="current-password" required>
            </div>
            <button class="btn btn-primary w-100" type="submit"><%= t('login') %></button>
          </form>

          <hr class="section-rule ornate">

          <p class="mb-2" style="font-size:.82rem;text-align:center;color:var(--muted)"><%= t('continue_free_providers') %></p>
          <div class="d-flex gap-2">
            <a class="btn btn-outline-secondary w-100" href="/auth/google">Google</a>
            <a class="btn btn-outline-secondary w-100" href="/auth/github">GitHub</a>
          </div>

          <p class="mt-3 mb-0 text-center" style="font-size:.85rem;color:var(--muted)">
            <%= t('need_account') %> <a href="/signup"><%= t('sign_up') %></a>
          </p>
        </div>
      </div>

    </div>
  </div>
</main>
</body>
</html>

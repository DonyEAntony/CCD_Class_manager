<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <main class="container py-5 app-shell">
    <div class="d-flex justify-content-end gap-2 mb-3">
      <span class="text-secondary"><%= t('language') %>:</span>
      <a href="/lang/en" class="btn btn-sm <%= lang === 'en' ? 'btn-primary' : 'btn-outline-primary' %>"><%= t('english') %></a>
      <a href="/lang/es" class="btn btn-sm <%= lang === 'es' ? 'btn-primary' : 'btn-outline-primary' %>"><%= t('spanish') %></a>
    </div>
    <div class="row justify-content-center">
      <div class="col-md-8 col-lg-6">
        <div class="card page-card">
          <div class="card-header p-3"><h1 class="h4 mb-0"><%= t('login') %></h1></div>
          <div class="card-body p-4">
            <% if (error.length) { %><div class="alert alert-danger"><%= error[0] %></div><% } %>
            <% if (success.length) { %><div class="alert alert-success"><%= success[0] %></div><% } %>
            <form method="post" action="/login" class="d-grid gap-3">
              <div>
                <label class="form-label"><%= t('email') %></label>
                <input class="form-control" type="email" name="email" required>
              </div>
              <div>
                <label class="form-label"><%= t('password') %></label>
                <input class="form-control" type="password" name="password" required>
              </div>
              <button class="btn btn-primary" type="submit"><%= t('login') %></button>
            </form>
            <hr>
            <p class="mb-2"><%= t('continue_free_providers') %></p>
            <div class="d-flex gap-2 flex-wrap">
              <a class="btn btn-outline-danger" href="/auth/google">Google</a>
              <a class="btn btn-outline-dark" href="/auth/github">GitHub</a>
            </div>
            <p class="mt-3 mb-0"><%= t('need_account') %> <a href="/signup"><%= t('sign_up') %></a></p>
          </div>
        </div>
      </div>
    </div>
  </main>
</body>
</html>

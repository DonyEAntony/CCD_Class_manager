<!doctype html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>User Administration &mdash; St. Matthew CCD</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,400&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body>

<%- include('_topbar') %>

<main class="container py-4 app-shell mx-auto">

  <% if (success.length) { %><div class="alert alert-success mb-3"><%= success[0] %></div><% } %>

  <div class="page-heading d-flex flex-wrap justify-content-between align-items-end gap-2">
    <div>
      <h1><%= t('user_administration') %></h1>
      <p class="sub mb-0">Manage roles and access for all registered users</p>
    </div>
    <a class="btn btn-outline-secondary" href="/dashboard"><%= t('back_to_dashboard') %></a>
  </div>

  <div class="page-card">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table mb-0">
          <thead>
            <tr>
              <th><%= t('email') %></th>
              <th><%= t('role') %></th>
              <th><%= t('provider') %></th>
              <th><%= t('update_role') %></th>
            </tr>
          </thead>
          <tbody>
            <% users.forEach(u => { %>
              <tr>
                <td><%= u.email %></td>
                <td><span class="badge badge-role badge-<%= u.role %>"><%= u.role %></span></td>
                <td style="font-size:.85rem;color:var(--muted)"><%= u.provider %></td>
                <td>
                  <form class="d-flex gap-2" method="post" action="/admin/users/<%= u.id %>/role">
                    <select class="form-select" name="role" style="max-width:140px">
                      <option value="parent" <%= u.role==='parent'?'selected':'' %>>Parent</option>
                      <option value="catechist" <%= u.role==='catechist'?'selected':'' %>>Catechist</option>
                      <option value="admin" <%= u.role==='admin'?'selected':'' %>>Admin</option>
                    </select>
                    <button class="btn btn-primary" type="submit"><%= t('save') %></button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <p class="footer-note"><%= t('footer_note') %></p>
</main>
</body>
</html>

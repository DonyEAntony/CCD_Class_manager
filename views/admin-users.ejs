<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Users</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <main class="container py-4 app-shell">
    <div class="d-flex justify-content-end gap-2 mb-3">
      <span class="text-secondary"><%= t('language') %>:</span>
      <a href="/lang/en" class="btn btn-sm <%= lang === 'en' ? 'btn-primary' : 'btn-outline-primary' %>"><%= t('english') %></a>
      <a href="/lang/es" class="btn btn-sm <%= lang === 'es' ? 'btn-primary' : 'btn-outline-primary' %>"><%= t('spanish') %></a>
    </div>
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h1 class="h3 mb-0"><%= t('user_administration') %></h1>
      <a class="btn btn-outline-secondary" href="/dashboard"><%= t('back_to_dashboard') %></a>
    </div>

    <% if (success.length) { %><div class="alert alert-success"><%= success[0] %></div><% } %>

    <div class="card page-card">
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0 align-middle">
            <thead>
              <tr><th><%= t('email') %></th><th><%= t('role') %></th><th><%= t('provider') %></th><th><%= t('update_role') %></th></tr>
            </thead>
            <tbody>
              <% users.forEach(u => { %>
                <tr>
                  <td><%= u.email %></td>
                  <td><span class="badge text-bg-secondary badge-role"><%= u.role %></span></td>
                  <td><%= u.provider %></td>
                  <td>
                    <form class="d-flex gap-2" method="post" action="/admin/users/<%= u.id %>/role">
                      <select class="form-select" name="role">
                        <option value="parent">Parent</option>
                        <option value="catechist">Catechist</option>
                        <option value="admin">Admin</option>
                      </select>
                      <button class="btn btn-primary" type="submit"><%= t('save') %></button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </main>
</body>
</html>

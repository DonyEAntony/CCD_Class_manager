<!doctype html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Eucharistic Adoration Signup &mdash; <%= t('app_title') %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
  <style>
    .adoration-hero {
      background:
        radial-gradient(circle at top right, rgba(232, 184, 75, 0.22), transparent 32%),
        linear-gradient(135deg, var(--navy) 0%, #203761 58%, #345691 100%);
      color: #fff;
      border-radius: 18px;
      padding: 2rem;
      position: relative;
      overflow: hidden;
    }
    .adoration-hero p:last-child {
      margin-bottom: 0;
    }
    .slot-note {
      background: var(--gold-pale);
      border: 1px solid #f0d090;
      border-radius: 10px;
      padding: 1rem 1.1rem;
      color: #7a5a1a;
      font-size: 0.9rem;
    }
  </style>
</head>
<body>
<%- include('_topbar') %>
<main class="container py-4 app-shell mx-auto">
  <% if (success.length) { %><div class="alert alert-success mb-3"><%= success[0] %></div><% } %>
  <% if (error.length) { %><div class="alert alert-danger mb-3"><%= error[0] %></div><% } %>

  <section class="adoration-hero mb-4">
    <p style="text-transform:uppercase;letter-spacing:.14em;font-size:.72rem;font-weight:700;color:rgba(255,255,255,.72)">Prayer Ministry</p>
    <h1 style="color:#fff;margin-bottom:.6rem">Eucharistic Adoration Signup</h1>
    <p style="max-width:640px;color:rgba(255,255,255,.82)">Use this independent signup form to reserve a 30-minute Eucharistic Adoration time. Available slots run from 8:30 AM through 4:00 PM.</p>
  </section>

  <div class="row g-4">
    <div class="col-lg-7">
      <div class="page-card">
        <div class="card-header"><h2 class="h5 mb-0">Reserve Your Time</h2></div>
        <div class="card-body">
          <form class="row g-3" method="post" action="/eucharistic-adoration">
            <div class="col-12">
              <label class="form-label required">Full Name</label>
              <input class="form-control" type="text" name="full_name" autocomplete="name" required>
            </div>
            <div class="col-md-6">
              <label class="form-label required">Email</label>
              <input class="form-control" type="email" name="email" autocomplete="email" required>
            </div>
            <div class="col-md-6">
              <label class="form-label required">Phone</label>
              <input class="form-control" type="tel" name="phone" autocomplete="tel" pattern="[0-9]{3}[.\- ]?[0-9]{3}[.\- ]?[0-9]{4}" title="Format: 123-456-7890 or 123.456.7890 or 123 456 7890" required>
            </div>
            <div class="col-md-6">
              <label class="form-label required">Date</label>
              <input class="form-control" type="date" name="adoration_date" min="<%= minDate %>" required>
            </div>
            <div class="col-md-6">
              <label class="form-label required">Time Slot</label>
              <select class="form-select" name="slot_start_time" required>
                <option value="">Select a time slot</option>
                <% timeSlots.forEach((slot) => { %>
                  <option value="<%= slot.value %>"><%= slot.label %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-12">
              <label class="form-label">Notes</label>
              <textarea class="form-control" name="notes" rows="4" placeholder="Optional prayer intention, scheduling note, or follow-up detail"></textarea>
            </div>
            <div class="col-12 d-flex flex-wrap gap-2">
              <button class="btn btn-primary" type="submit">Submit Signup</button>
              <a class="btn btn-outline-secondary" href="/">Back to Home</a>
            </div>
          </form>
        </div>
      </div>
    </div>

    <div class="col-lg-5">
      <div class="slot-note mb-3">
        Each signup reserves one 30-minute period. If a slot is already taken for a chosen date, the form will ask you to pick another time.
      </div>
      <div class="page-card">
        <div class="card-header"><h2 class="h5 mb-0">Available Daily Slots</h2></div>
        <div class="card-body">
          <div class="d-flex flex-column gap-2">
            <% timeSlots.forEach((slot) => { %>
              <div style="border:1px solid var(--border);border-radius:8px;padding:.75rem .9rem;background:var(--off-white);font-size:.92rem">
                <strong style="color:var(--navy)"><%= slot.label %></strong>
              </div>
            <% }) %>
          </div>
        </div>
      </div>
    </div>
  </div>
</main>
</body>
</html>

<!doctype html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Verification Email Preview &mdash; <%= t('app_title') %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
<%- include('_topbar') %>
<main class="container py-4 app-shell mx-auto">
  <div class="page-heading d-flex flex-wrap justify-content-between align-items-end gap-2">
    <div>
      <h1>Verification Email Preview</h1>
      <p class="sub mb-0"><strong><%= targetUser.email %></strong></p>
    </div>
    <a class="btn btn-outline-secondary" href="/admin/users">Back to Admin</a>
  </div>

  <div class="page-card mb-4">
    <div class="card-body">
      <p class="mb-2"><strong>Subject:</strong> <%= emailPreview.subject %></p>
      <p class="mb-2"><strong>Recipient:</strong> <%= targetUser.email %></p>
      <p class="mb-0"><strong>Verification Link Preview:</strong> <code><%= verificationUrl %></code></p>
    </div>
  </div>

  <div class="page-card mb-4">
    <div class="card-header"><h2 class="h5 mb-0">Plain Text</h2></div>
    <div class="card-body">
      <pre class="mb-0" style="white-space:pre-wrap"><%= emailPreview.text %></pre>
    </div>
  </div>

  <div class="page-card">
    <div class="card-header"><h2 class="h5 mb-0">HTML Preview</h2></div>
    <div class="card-body">
      <%- emailPreview.html %>
    </div>
  </div>
</main>
</body>
</html>

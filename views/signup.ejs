<!doctype html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Create Account &mdash; St. Matthew CCD</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,400&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body>

<%- include('_topbar') %>

<main class="container py-5 app-shell mx-auto">
  <div class="row justify-content-center">
    <div class="col-md-10 col-lg-7">

      <div style="text-align:center;margin-bottom:1.5rem">
        <span style="font-size:2.5rem;color:var(--gold)">✦</span>
        <h1 style="font-family:'Cormorant Garamond',serif;font-size:2rem;margin:.25rem 0 0"><%= t('create_login') %></h1>
        <p style="font-size:.85rem;color:var(--muted)">Saint Matthew Catholic Church</p>
      </div>

      <div class="page-card">
        <div class="card-body p-4">
          <% if (error.length) { %><div class="alert alert-danger"><%= error[0] %></div><% } %>

          <form method="post" action="/signup" class="row g-3">
            <div class="col-12">
              <label class="form-label"><%= t('email') %></label>
              <input class="form-control" type="email" name="email" autocomplete="email" required>
            </div>
            <div class="col-12">
              <label class="form-label"><%= t('full_name') %></label>
              <input class="form-control" type="text" name="fullName" autocomplete="name">
            </div>
            <div class="col-md-6">
              <label class="form-label"><%= t('password') %></label>
              <input class="form-control" type="password" name="password" autocomplete="new-password" required>
            </div>
            <div class="col-md-6">
              <label class="form-label"><%= t('role_request') %></label>
              <select class="form-select" name="requestedRole">
                <option value="parent"><%= t('parent') %></option>
                <option value="catechist">Catechist</option>
                <option value="admin">Admin</option>
              </select>
            </div>
            <div class="col-12">
              <label class="form-label"><%= t('invite_code') %></label>
              <input class="form-control" type="text" name="inviteCode" placeholder="Leave blank for parent role">
            </div>
            <div class="col-12 d-flex gap-2">
              <button class="btn btn-primary" type="submit"><%= t('create_account') %></button>
              <a class="btn btn-outline-secondary" href="/login"><%= t('already_have_account') %></a>
            </div>
          </form>
        </div>
      </div>

    </div>
  </div>
</main>
</body>
</html>

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Create Account</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <main class="container py-5 app-shell">
    <div class="row justify-content-center">
      <div class="col-md-10 col-lg-7">
        <div class="card page-card">
          <div class="card-header p-3"><h1 class="h4 mb-0">Create Login</h1></div>
          <div class="card-body p-4">
            <% if (error.length) { %><div class="alert alert-danger"><%= error[0] %></div><% } %>
            <form method="post" action="/signup" class="row g-3">
              <div class="col-12">
                <label class="form-label">Email</label>
                <input class="form-control" type="email" name="email" required>
              </div>
              <div class="col-12">
                <label class="form-label">Full Name</label>
                <input class="form-control" type="text" name="fullName">
              </div>
              <div class="col-md-6">
                <label class="form-label">Password</label>
                <input class="form-control" type="password" name="password" required>
              </div>
              <div class="col-md-6">
                <label class="form-label">Role Request</label>
                <select class="form-select" name="requestedRole">
                  <option value="parent">Parent</option>
                  <option value="catechist">Catechist</option>
                  <option value="admin">Admin</option>
                </select>
              </div>
              <div class="col-12">
                <label class="form-label">Invite Code (required for admin/catechist)</label>
                <input class="form-control" type="text" name="inviteCode">
              </div>
              <div class="col-12 d-flex gap-2">
                <button class="btn btn-primary" type="submit">Create account</button>
                <a class="btn btn-outline-secondary" href="/login">Already have an account?</a>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </main>
</body>
</html>

<!doctype html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= t('create_login') %> &mdash; <%= t('app_title') %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
<%- include('_topbar') %>
<main class="container py-5 app-shell mx-auto">
  <div class="row justify-content-center">
    <div class="col-md-10 col-lg-6">

      <div style="text-align:center;margin-bottom:1.5rem">
        <span style="font-size:2.5rem;color:var(--gold)">✦</span>
        <h1 style="font-family:'Playfair Display',Georgia,serif;font-size:2rem;margin:.25rem 0 0"><%= t('create_login') %></h1>
        <p style="font-size:.85rem;color:var(--muted)"><%= t('app_title') %></p>
      </div>

      <div class="page-card">
        <div class="card-body p-4">
          <% if (error.length) { %><div class="alert alert-danger mb-3"><%= error[0] %></div><% } %>

          <form method="post" action="/signup" class="row g-3">
            <div class="col-12">
              <label class="form-label"><%= t('email') %></label>
              <input class="form-control" type="email" name="email" autocomplete="email" required>
            </div>
            <div class="col-md-6">
              <label class="form-label"><%= t('first_name') || 'First Name' %></label>
              <input class="form-control" type="text" name="firstName" autocomplete="given-name" required>
            </div>
            <div class="col-md-6">
              <label class="form-label"><%= t('last_name') || 'Last Name' %></label>
              <input class="form-control" type="text" name="lastName" autocomplete="family-name" required>
            </div>
            <div class="col-12">
              <label class="form-label"><%= t('phone') %></label>
              <input class="form-control" type="tel" name="phone" autocomplete="tel" pattern="[0-9]{3}[.\\- ]?[0-9]{3}[.\\- ]?[0-9]{4}" title="Format: 123-456-7890 or 123.456.7890 or 123 456 7890" required>
            </div>
            <div class="col-12">
              <label class="form-label"><%= t('password') %></label>
              <input class="form-control" type="password" name="password" autocomplete="new-password" required>
            </div>

            <div class="col-12">
              <p class="form-label mb-2"><%= t('are_you_staff') %></p>
              <div class="d-flex flex-column gap-2">
                <label id="catechist-check-wrap" class="d-flex align-items-start gap-2 p-3 rounded"
                  style="border:1px solid var(--border);cursor:pointer;background:var(--off-white);transition:all .15s">
                  <input class="form-check-input mt-0 flex-shrink-0" type="checkbox"
                    name="requestedRole" value="catechist" id="check-catechist">
                  <div>
                    <span style="font-weight:600;font-size:.9rem"><%= t('i_am_catechist') %></span>
                    <p class="mb-0" style="font-size:.78rem;color:var(--muted)"><%= t('catechist_desc') %></p>
                  </div>
                </label>
                <label id="admin-check-wrap" class="d-flex align-items-start gap-2 p-3 rounded"
                  style="border:1px solid var(--border);cursor:pointer;background:var(--off-white);transition:all .15s">
                  <input class="form-check-input mt-0 flex-shrink-0" type="checkbox"
                    name="requestedRole" value="admin" id="check-admin">
                  <div>
                    <span style="font-weight:600;font-size:.9rem"><%= t('i_am_admin') %></span>
                    <p class="mb-0" style="font-size:.78rem;color:var(--muted)"><%= t('admin_desc') %></p>
                  </div>
                </label>
              </div>
              <p class="mt-2 mb-0" style="font-size:.78rem;color:var(--muted)"><%= t('leave_unchecked') %></p>
            </div>

            <div class="col-12 d-none" id="invite-code-wrap">
              <label class="form-label"><%= t('invite_code') %></label>
              <input class="form-control" type="text" name="inviteCode" id="inviteCode"
                placeholder="<%= t('invite_placeholder') %>">
              <p class="mt-1 mb-0" style="font-size:.75rem;color:var(--muted)"><%= t('contact_parish_code') %></p>
            </div>

            <div class="col-12 d-flex gap-2 pt-1">
              <button class="btn btn-primary" type="submit"><%= t('create_account') %></button>
              <a class="btn btn-outline-secondary" href="/login"><%= t('already_have_account') %></a>
            </div>
          </form>
        </div>
      </div>

    </div>
  </div>
</main>
<script>
  const catechist = document.getElementById('check-catechist');
  const admin     = document.getElementById('check-admin');
  const wrap      = document.getElementById('invite-code-wrap');
  const input     = document.getElementById('inviteCode');
  function updateUI() {
    const on = catechist.checked || admin.checked;
    wrap.classList.toggle('d-none', !on);
    input.required = on;
    const cw = document.getElementById('catechist-check-wrap');
    const aw = document.getElementById('admin-check-wrap');
    cw.style.borderColor = catechist.checked ? 'var(--blue-sky)' : 'var(--border)';
    cw.style.background  = catechist.checked ? 'var(--blue-light)' : 'var(--off-white)';
    aw.style.borderColor = admin.checked     ? 'var(--blue-sky)' : 'var(--border)';
    aw.style.background  = admin.checked     ? 'var(--blue-light)' : 'var(--off-white)';
  }
  catechist.addEventListener('change', () => { if (catechist.checked) admin.checked = false; updateUI(); });
  admin.addEventListener('change',     () => { if (admin.checked) catechist.checked = false; updateUI(); });
</script>
</body>
</html>

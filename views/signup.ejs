<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Create Account</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <main class="container py-5 app-shell">
    <div class="d-flex justify-content-end gap-2 mb-3">
      <span class="text-secondary"><%= t('language') %>:</span>
      <a href="/lang/en" class="btn btn-sm <%= lang === 'en' ? 'btn-primary' : 'btn-outline-primary' %>"><%= t('english') %></a>
      <a href="/lang/es" class="btn btn-sm <%= lang === 'es' ? 'btn-primary' : 'btn-outline-primary' %>"><%= t('spanish') %></a>
    </div>
    <div class="row justify-content-center">
      <div class="col-md-10 col-lg-7">
        <div class="card page-card">
          <div class="card-header p-3"><h1 class="h4 mb-0"><%= t('create_login') %></h1></div>
          <div class="card-body p-4">
            <% if (error.length) { %><div class="alert alert-danger"><%= error[0] %></div><% } %>
            <form method="post" action="/signup" class="row g-3">
              <div class="col-12">
                <label class="form-label"><%= t('email') %></label>
                <input class="form-control" type="email" name="email" required>
              </div>
              <div class="col-12">
                <label class="form-label"><%= t('full_name') %></label>
                <input class="form-control" type="text" name="fullName">
              </div>
              <div class="col-md-6">
                <label class="form-label"><%= t('password') %></label>
                <input class="form-control" type="password" name="password" required>
              </div>
              <div class="col-md-6">
                <label class="form-label"><%= t('role_request') %></label>
                <select class="form-select" name="requestedRole">
                  <option value="parent"><%= t('parent') %></option>
                  <option value="catechist">Catechist</option>
                  <option value="admin">Admin</option>
                </select>
              </div>
              <div class="col-12">
                <label class="form-label"><%= t('invite_code') %></label>
                <input class="form-control" type="text" name="inviteCode">
              </div>
              <div class="col-12 d-flex gap-2">
                <button class="btn btn-primary" type="submit"><%= t('create_account') %></button>
                <a class="btn btn-outline-secondary" href="/login"><%= t('already_have_account') %></a>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </main>
</body>
</html>

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>St Matthew CCD</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <main class="container py-5 app-shell">
    <section class="hero p-4 p-md-5 mb-4">
      <h1 class="display-6 fw-bold brand-title mb-2">Saint Matthew Catholic Church</h1>
      <p class="lead mb-1">Registration for Religious Education</p>
      <p class="mb-0">School Year 2025-2026</p>
    </section>

    <div class="card page-card">
      <div class="card-body p-4">
        <p class="text-secondary">Secure online registration for families, catechists, and administrators.</p>
        <% if (user) { %>
          <div class="d-flex flex-wrap gap-2 align-items-center">
            <span class="badge text-bg-primary badge-role"><%= user.role %></span>
            <span class="text-secondary">Signed in as <strong><%= user.email %></strong></span>
            <a class="btn btn-primary" href="/dashboard">Open Dashboard</a>
            <a class="btn btn-outline-secondary" href="/logout">Logout</a>
          </div>
        <% } else { %>
          <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-primary" href="/signup">Create Account</a>
            <a class="btn btn-outline-primary" href="/login">Login</a>
          </div>
        <% } %>
      </div>
    </div>
  </main>
</body>
</html>

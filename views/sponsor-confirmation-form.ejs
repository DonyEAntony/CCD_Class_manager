<!doctype html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Student/Sponsor Confirmation Information &mdash; <%= t('app_title') %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
<%- include('_topbar') %>

<main class="container py-4 app-shell mx-auto">
  <div class="page-heading d-flex flex-wrap justify-content-between align-items-end gap-2">
    <div>
      <h1>Student/Sponsor Confirmation Information</h1>
      <p class="sub mb-0"><%= typeof schoolYearLabel === 'string' ? schoolYearLabel : '' %></p>
    </div>
    <a class="btn btn-outline-secondary" href="/dashboard">Back</a>
  </div>

  <div class="page-card">
    <% if (error && error.length) { %><div class="alert alert-danger m-4 mb-0"><%= error[0] %></div><% } %>
    <% if (success && success.length) { %><div class="alert alert-success m-4 mb-0"><%= success[0] %></div><% } %>
    <div class="card-body p-4">
      <div class="alert alert-secondary mb-4">
        Return to the Religious Education office along with a Sponsor Certificate.
      </div>
      <form method="post" action="/registration/sponsor-confirmation" enctype="multipart/form-data" class="row g-3">
        <input type="hidden" name="registration_id" value="<%= reg ? reg.id : '' %>">

        <fieldset class="col-12">
          <legend>Student</legend>
          <div class="row g-3">
            <div class="col-12">
              <label class="form-label required">Student's Name</label>
              <input class="form-control" type="text" name="student_name" value="<%= reg ? reg.student_name : '' %>" required>
            </div>
            <div class="col-12">
              <label class="form-label required">Student's Confirmation Name</label>
              <input class="form-control" type="text" name="confirmation_name" value="<%= reg ? reg.confirmation_name : '' %>" required>
              <div class="form-text sponsor-form-help">Your choice must be a saint's name.</div>
            </div>
          </div>
        </fieldset>

        <fieldset class="col-12">
          <legend>Sponsor</legend>
          <div class="row g-3">
            <div class="col-12">
              <label class="form-label required">Sponsor's Name</label>
              <input class="form-control" type="text" name="sponsor_name" value="<%= reg ? reg.sponsor_name : '' %>" required>
            </div>
            <div class="col-12">
              <label class="form-label required">Sponsor's Address</label>
              <input class="form-control" type="text" name="sponsor_address" value="<%= reg ? reg.sponsor_address : '' %>" required>
            </div>
            <div class="col-md-6">
              <label class="form-label required">City</label>
              <input class="form-control" type="text" name="sponsor_city" value="<%= reg ? reg.sponsor_city : '' %>" required>
            </div>
            <div class="col-md-3">
              <label class="form-label required">State</label>
              <input class="form-control" type="text" name="sponsor_state" maxlength="50" value="<%= reg ? reg.sponsor_state : '' %>" required>
            </div>
            <div class="col-md-3">
              <label class="form-label required">Zip Code</label>
              <input class="form-control" type="text" name="sponsor_zip" maxlength="20" value="<%= reg ? reg.sponsor_zip : '' %>" required>
            </div>
          </div>
        </fieldset>

        <div class="col-12">
          <div class="alert alert-info mb-0">
            The sponsor must obtain a Sponsor Certificate issued from their parish stating that he/she is a practicing member of the Catholic faith in that parish.
          </div>
        </div>

        <fieldset class="col-12">
          <legend>Sponsor Certificate</legend>
          <div class="row g-3">
            <div class="col-12">
              <label class="form-label">Attach Scanned Sponsor Certificate</label>
              <input class="form-control" type="file" name="sponsor_certificate" accept=".pdf,image/*">
              <% if (reg && reg.sponsor_certificate_path) { %>
                <div class="form-text mt-2">
                  Current file:
                  <a href="/<%= reg.sponsor_certificate_path %>">View Sponsor Certificate</a>
                </div>
              <% } %>
            </div>
          </div>
        </fieldset>

        <fieldset class="col-12">
          <legend>Signatures</legend>
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label required">Student's Signature</label>
              <input class="form-control" type="text" name="student_signature" value="<%= reg ? reg.student_signature : '' %>" required>
            </div>
            <div class="col-md-6">
              <label class="form-label required">Parent's Signature</label>
              <input class="form-control" type="text" name="parent_signature" value="<%= reg ? reg.parent_signature : '' %>" required>
            </div>
          </div>
        </fieldset>

        <div class="col-12 d-flex gap-2">
          <button class="btn btn-primary" type="submit"><%= reg ? 'Update Form' : 'Save Form' %></button>
          <a class="btn btn-outline-secondary" href="/dashboard">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</main>
</body>
</html>

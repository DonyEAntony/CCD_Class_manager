<!doctype html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= t('dashboard') %> &mdash; <%= t('app_title') %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Hedvig+Letters+Serif:opsz@12..24&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
  <style>
    .program-card {
      border: 1px solid var(--border);
      border-radius: 10px;
      background: var(--white);
      padding: 1.4rem 1.25rem 1.25rem;
      text-decoration: none;
      display: block;
      transition: box-shadow 0.18s, transform 0.18s, border-color 0.18s;
      height: 100%;
    }
    .program-card:hover {
      box-shadow: 0 6px 24px var(--shadow-md);
      transform: translateY(-2px);
      border-color: var(--blue-sky);
      text-decoration: none;
    }
    .program-card .prog-icon {
      width: 42px; height: 42px;
      border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.2rem;
      margin-bottom: 0.85rem;
    }
    .program-card .prog-title {
      font-family: 'Hedvig Letters Serif', Georgia, serif;
      font-size: 1.05rem; font-weight: 600;
      color: var(--navy); margin-bottom: 0.15rem;
    }
    .program-card .prog-subtitle {
      font-size: 0.75rem; color: var(--blue-sky);
      font-weight: 600; text-transform: uppercase;
      letter-spacing: 0.05em; margin-bottom: 0.5rem;
    }
    .program-card .prog-desc {
      font-size: 0.82rem; color: var(--muted); line-height: 1.5; margin: 0;
    }
    .prog-children .prog-icon { background: rgba(26,39,68,0.08); color: var(--navy); }
    .prog-family   .prog-icon { background: rgba(59,115,87,0.12); color: var(--forest); }
    .prog-ocia     .prog-icon { background: rgba(26,39,68,0.08); color: var(--navy); }
    .prog-baptism  .prog-icon { background: rgba(74,127,193,0.12); color: var(--blue-sky); }
    .prog-confirm  .prog-icon { background: rgba(200,146,42,0.12); color: var(--gold); }
    .prog-sponsor  .prog-icon { background: rgba(26,39,68,0.08); color: var(--navy-soft); }
    .section-label {
      font-size: 0.68rem; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.1em; color: var(--muted); margin-bottom: 0.75rem;
    }
  </style>
</head>
<body>
<%- include('_topbar') %>
<main class="container py-4 app-shell mx-auto">

  <% if (success.length) { %><div class="alert alert-success mb-3"><%= success[0] %></div><% } %>
  <% if (error.length) { %><div class="alert alert-danger mb-3"><%= error[0] %></div><% } %>

  <div class="page-heading d-flex flex-wrap justify-content-between align-items-end gap-2">
    <div>
      <h1><%= t('dashboard') %></h1>
      <p class="sub mb-0">
        <%= t('signed_in_as') %> <strong><%= user.email %></strong>
        &ensp;<span class="badge badge-role badge-<%= user.role %>"><%= user.role %></span>
      </p>
    </div>
    <div class="d-flex flex-wrap gap-2">
      <% if (user.role === 'admin') { %>
        <a class="btn btn-outline-primary" href="/admin/users"><%= t('manage_users') %></a>
      <% } %>
      <% if (user.role === 'admin' || user.role === 'family_faith_leader') { %>
        <a class="btn btn-outline-primary" href="/family-faith/visits/availability"><%= t('manage_visit_availability') %></a>
      <% } %>
      <a class="btn btn-outline-primary" href="/calendar"><%= t('calendar') %></a>
      <a class="btn btn-outline-secondary" href="/logout"><%= t('logout') %></a>
    </div>
  </div>

  <!-- Registration Menu -->
  <div class="page-card mb-4">
    <div class="card-header"><h2 class="h5"><%= t('new_registration_heading') %></h2></div>
    <div class="card-body">

      <p class="section-label"><%= t('childrens_programs') %></p>
      <% const canOpenFaithFormation = user.role === 'admin' || user.role === 'catechist' || (faithFormationSettings && faithFormationSettings.faithFormationRegistrationOpen); %>
      <% const canOpenSponsorForm = user.role === 'admin' || user.role === 'catechist' || (faithFormationSettings && faithFormationSettings.sponsorFormRegistrationOpen); %>
      <div class="row g-3 mb-4">
        <div class="col-sm-6 col-lg-4">
          <a href="<%= canOpenFaithFormation ? '/registration/children' : '#' %>" class="program-card prog-children <%= canOpenFaithFormation ? '' : 'opacity-75' %>">
            <div class="prog-icon">🎓</div>
            <div class="prog-title"><%= t('prog_children_title') %></div>
            <div class="prog-subtitle"><%= faithFormationSettings && faithFormationSettings.schoolYear ? `School Year ${faithFormationSettings.schoolYear}` : t('prog_children_subtitle') %></div>
            <p class="prog-desc"><%= canOpenFaithFormation ? t('prog_children_desc') : 'Registration is currently closed. Contact the parish office or wait for an admin to open this year.' %></p>
          </a>
        </div>
        <div class="col-sm-6 col-lg-4">
          <a href="<%= canOpenSponsorForm ? '/registration/sponsor-confirmation' : '#' %>" class="program-card prog-sponsor <%= canOpenSponsorForm ? '' : 'opacity-75' %>">
            <div class="prog-icon">SC</div>
            <div class="prog-title">Confirmation Sponsor Form</div>
            <div class="prog-subtitle"><%= faithFormationSettings && faithFormationSettings.schoolYear ? `School Year ${faithFormationSettings.schoolYear}` : 'Student / Sponsor' %></div>
            <p class="prog-desc"><%= canOpenSponsorForm ? 'Enter and save sponsor confirmation information, including sponsor address and signatures.' : 'Unavailable until the Sponsor Form is opened by an administrator.' %></p>
          </a>
        </div>
      </div>

      <p class="section-label"><%= t('family_programs') %></p>
      <div class="row g-3 mb-4">
        <div class="col-sm-6 col-lg-4">
          <a href="/registration/family-faith" class="program-card prog-family">
            <div class="prog-icon">FF</div>
            <div class="prog-title"><%= t('prog_family_title') %></div>
            <div class="prog-subtitle"><%= t('prog_family_subtitle') %></div>
            <p class="prog-desc"><%= t('prog_family_desc') %></p>
          </a>
        </div>
      </div>

      <p class="section-label"><%= t('adult_programs') %></p>
      <div class="row g-3">
        <div class="col-sm-6 col-lg-4">
          <a href="/registration/adult/ocia" class="program-card prog-ocia">
            <div class="prog-icon"><%= ADULT_PROGRAMS.ocia.icon %></div>
            <div class="prog-title"><%= ADULT_PROGRAMS.ocia.title %></div>
            <div class="prog-subtitle"><%= ADULT_PROGRAMS.ocia.subtitle %></div>
            <p class="prog-desc"><%= ADULT_PROGRAMS.ocia.description %></p>
          </a>
        </div>
        <div class="col-sm-6 col-lg-4">
          <a href="/registration/adult/baptism_prep" class="program-card prog-baptism">
            <div class="prog-icon"><%= ADULT_PROGRAMS.baptism_prep.icon %></div>
            <div class="prog-title"><%= ADULT_PROGRAMS.baptism_prep.title %></div>
            <div class="prog-subtitle"><%= ADULT_PROGRAMS.baptism_prep.subtitle %></div>
            <p class="prog-desc"><%= ADULT_PROGRAMS.baptism_prep.description %></p>
          </a>
        </div>
        <div class="col-sm-6 col-lg-4">
          <a href="/registration/adult/adult_confirmation" class="program-card prog-confirm">
            <div class="prog-icon"><%= ADULT_PROGRAMS.adult_confirmation.icon %></div>
            <div class="prog-title"><%= ADULT_PROGRAMS.adult_confirmation.title %></div>
            <div class="prog-subtitle"><%= ADULT_PROGRAMS.adult_confirmation.subtitle %></div>
            <p class="prog-desc"><%= ADULT_PROGRAMS.adult_confirmation.description %></p>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Children Registrations -->
  <div class="page-card mb-4">
    <div class="card-header"><h2 class="h5"><%= t('faith_formation_children') %></h2></div>
    <div class="card-body p-0">
      <% if (!studentRegs || studentRegs.length === 0) { %>
        <div class="p-4 text-center" style="color:var(--muted);font-size:.9rem"><em><%= t('no_children_regs') %></em></div>
      <% } else { %>
      <div class="table-responsive">
        <table class="table mb-0">
          <thead>
            <tr>
              <th><%= t('student') %></th>
              <th><%= t('grade') %></th>
              <th><%= t('primary_contact') %></th>
              <th><%= t('total_fees') %></th>
              <th><%= t('certificates') %></th>
              <th><%= t('status') %></th>
              <th><%= t('actions') %></th>
            </tr>
          </thead>
          <tbody>
          <% studentRegs.forEach(r => { %>
            <tr>
              <td style="font-weight:600"><%= r.student_full_name %></td>
              <td><%= r.ccd_grade_level || '&mdash;' %></td>
              <td style="font-size:.85rem"><%= r.parent_name || r.primary_contact_email || '&mdash;' %></td>
              <td><strong>$<%= (r.registration_fee||0)+(r.sacramental_fee||0)+(r.late_fee||0) %></strong></td>
              <td style="font-size:.85rem">
                <% if (r.baptism_certificate_path) { %><a href="/<%= r.baptism_certificate_path %>"><%= t('baptism') %></a><% } %>
                <% if (r.baptism_certificate_path && r.first_communion_certificate_path) { %> &middot; <% } %>
                <% if (r.first_communion_certificate_path) { %><a href="/<%= r.first_communion_certificate_path %>"><%= t('communion') %></a><% } %>
                <% if (!r.baptism_certificate_path && !r.first_communion_certificate_path) { %><span style="color:var(--muted)">&mdash;</span><% } %>
              </td>
              <td>
                <span class="badge" style="background:var(--surface);color:var(--navy-soft);font-size:.7rem;border-radius:2rem;padding:.3em .8em;font-weight:700;border:1px solid var(--border)">
                  <%= t(r.status) %>
                </span>
              </td>
              <td>
                <% if (canOpenFaithFormation) { %>
                  <a href="/registration/children/edit/<%= r.id %>" class="btn btn-sm btn-outline-primary"><%= t('edit') %></a>
                <% } else { %>
                  <button class="btn btn-sm btn-outline-secondary" type="button" disabled>Closed</button>
                <% } %>
              </td>
            </tr>
          <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>
  </div>

  <div class="page-card mb-4">
    <div class="card-header"><h2 class="h5"><%= t('family_faith_registrations') %></h2></div>
    <div class="card-body p-0">
      <% if (!familyRegs || familyRegs.length === 0) { %>
        <div class="p-4 text-center" style="color:var(--muted);font-size:.9rem"><em><%= t('no_family_regs') %></em></div>
      <% } else { %>
      <div class="table-responsive">
        <table class="table mb-0">
          <thead>
            <tr>
              <th><%= t('family_name') %></th>
              <th><%= t('family_primary_contact') %></th>
              <th><%= t('members_col') %></th>
              <th><%= t('family_badges') %></th>
              <th><%= t('visit_window') %></th>
              <th><%= t('status') %></th>
              <th><%= t('actions') %></th>
            </tr>
          </thead>
          <tbody>
          <% familyRegs.forEach((r) => { %>
            <tr>
              <td style="font-weight:600"><%= r.family_name %></td>
              <td style="font-size:.85rem">
                <div><%= r.primary_contact_name || '&mdash;' %></div>
                <div style="color:var(--muted)"><%= r.primary_contact_email || r.primary_contact_phone || '&mdash;' %></div>
              </td>
              <td style="font-size:.85rem">
                <% if (!r.members.length) { %>
                  <span style="color:var(--muted)">&mdash;</span>
                <% } else { %>
                  <% r.members.forEach((member) => { %>
                    <div>
                      <strong><%= [member.firstName, member.lastName].filter(Boolean).join(' ') %></strong>
                      <% if (member.role) { %><span style="color:var(--muted)">(<%= t(`role_${member.role}_member`) %>)</span><% } %>
                    </div>
                  <% }) %>
                <% } %>
              </td>
              <td style="font-size:.85rem">
                <% const membersWithNeeds = r.members.filter((member) => member.sacramentNeeds && member.sacramentNeeds.length); %>
                <% if (!membersWithNeeds.length) { %>
                  <span style="color:var(--muted)"><%= t('family_badges_none') %></span>
                <% } else { %>
                  <% membersWithNeeds.forEach((member) => { %>
                    <div class="mb-1">
                      <strong><%= [member.firstName, member.lastName].filter(Boolean).join(' ') %>:</strong>
                      <% member.sacramentNeeds.forEach((need) => { %>
                        <span class="badge" style="background:var(--surface);color:var(--navy-soft);font-size:.7rem;border-radius:2rem;padding:.3em .8em;font-weight:700;border:1px solid var(--border)"><%= t(need) %></span>
                      <% }) %>
                    </div>
                  <% }) %>
                <% } %>
              </td>
              <td style="font-size:.85rem">
                <% if (r.visit_label) { %>
                  <div><strong><%= t('visit') %>:</strong> <%= r.visit_label %></div>
                <% } else { %>
                  <span style="color:var(--muted)">&mdash;</span>
                <% } %>
              </td>
              <td>
                <span class="badge" style="background:var(--surface);color:var(--navy-soft);font-size:.7rem;border-radius:2rem;padding:.3em .8em;font-weight:700;border:1px solid var(--border)">
                  <%= t(r.status) %>
                </span>
              </td>
              <td>
                <a href="/registration/family-faith/edit/<%= r.id %>" class="btn btn-sm btn-outline-primary"><%= t('edit') %></a>
              </td>
            </tr>
          <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>
  </div>

  <!-- Adult Registrations -->
  <div class="page-card">
    <div class="card-header"><h2 class="h5"><%= t('adult_program_regs') %></h2></div>
    <div class="card-body p-0">
      <% if (!adultRegs || adultRegs.length === 0) { %>
        <div class="p-4 text-center" style="color:var(--muted);font-size:.9rem"><em><%= t('no_adult_regs') %></em></div>
      <% } else { %>
      <div class="table-responsive">
        <table class="table mb-0">
          <thead>
            <tr>
              <th><%= t('name_col') %></th>
              <th><%= t('program_col') %></th>
              <th><%= t('email') %></th>
              <th><%= t('phone') %></th>
              <th><%= t('date_col') %></th>
              <th><%= t('status') %></th>
              <th><%= t('actions') %></th>
            </tr>
          </thead>
          <tbody>
          <% adultRegs.forEach(r => { %>
            <% const prog = ADULT_PROGRAMS[r.program_type] || { title: r.program_type }; %>
            <tr>
              <td style="font-weight:600"><%= r.full_name %></td>
              <td>
                <span class="badge" style="background:var(--surface);color:var(--navy-soft);font-size:.7rem;border-radius:2rem;padding:.3em .8em;font-weight:700;border:1px solid var(--border)">
                  <%= prog.title %>
                </span>
              </td>
              <td style="font-size:.85rem"><%= r.email || '&mdash;' %></td>
              <td style="font-size:.85rem"><%= r.phone || '&mdash;' %></td>
              <td style="font-size:.8rem;color:var(--muted)"><%= r.created_at ? (typeof r.created_at === 'string' ? r.created_at.slice(0,10) : r.created_at.toISOString().slice(0,10)) : '' %></td>
              <td>
                <span class="badge" style="background:var(--surface);color:var(--navy-soft);font-size:.7rem;border-radius:2rem;padding:.3em .8em;font-weight:700;border:1px solid var(--border)">
                  <%= t(r.status) %>
                </span>
              </td>
              <td>
                <a href="/registration/adult/edit/<%= r.program_type %>/<%= r.id %>" class="btn btn-sm btn-outline-primary"><%= t('edit') %></a>
              </td>
            </tr>
          <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>
  </div>

  <div class="page-card mt-4">
    <div class="card-header"><h2 class="h5">Sponsor Confirmation Forms</h2></div>
    <div class="card-body p-0">
      <% if (!sponsorRegs || sponsorRegs.length === 0) { %>
        <div class="p-4 text-center" style="color:var(--muted);font-size:.9rem"><em>No sponsor confirmation forms yet.</em></div>
      <% } else { %>
      <div class="table-responsive">
        <table class="table mb-0">
          <thead>
            <tr>
              <th>Student</th>
              <th>Confirmation Name</th>
              <th>Sponsor</th>
              <th>Certificate</th>
              <th>Verification</th>
              <th>Submitted</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
          <% sponsorRegs.forEach(r => { %>
            <tr>
              <td style="font-weight:600"><%= r.student_name %></td>
              <td><%= r.confirmation_name || '&mdash;' %></td>
              <td><%= r.sponsor_name %></td>
              <td>
                <% if (Number(r.is_st_matthew_parishioner)) { %>
                  <span>St. Matthew parishioner</span>
                <% } else if (r.sponsor_certificate_path) { %>
                  <a href="/<%= r.sponsor_certificate_path %>">View File</a>
                <% } else { %>
                  <span style="color:var(--muted)">&mdash;</span>
                <% } %>
              </td>
              <td>
                <% if (Number(r.is_st_matthew_parishioner)) { %>
                  <% if (Number(r.admin_verified)) { %>
                    <span class="badge text-bg-success">Admin verified</span>
                  <% } else { %>
                    <span class="badge text-bg-warning">Pending admin review</span>
                  <% } %>
                <% } else if (r.sponsor_certificate_path) { %>
                  <span style="color:var(--muted)">Certificate provided</span>
                <% } else { %>
                  <span class="badge text-bg-danger">Missing certificate</span>
                <% } %>
              </td>
              <td style="font-size:.8rem;color:var(--muted)"><%= r.created_at ? (typeof r.created_at === 'string' ? r.created_at.slice(0,10) : r.created_at.toISOString().slice(0,10)) : '' %></td>
              <td>
                <span class="badge" style="background:var(--surface);color:var(--navy-soft);font-size:.7rem;border-radius:2rem;padding:.3em .8em;font-weight:700;border:1px solid var(--border)">
                  <%= t(r.status) %>
                </span>
              </td>
              <td>
                <% if (user && user.role === 'admin' && Number(r.is_st_matthew_parishioner) && !Number(r.admin_verified)) { %>
                  <form method="post" action="/admin/sponsor-confirmation/<%= r.id %>/verify" class="d-inline">
                    <button class="btn btn-sm btn-outline-success" type="submit">Verify</button>
                  </form>
                <% } %>
                <% if (canOpenSponsorForm) { %>
                  <a href="/registration/sponsor-confirmation/edit/<%= r.id %>" class="btn btn-sm btn-outline-primary"><%= t('edit') %></a>
                <% } else { %>
                  <button class="btn btn-sm btn-outline-secondary" type="button" disabled>Closed</button>
                <% } %>
                <% if (user && user.role === 'admin') { %>
                  <form method="post" action="/admin/sponsor-confirmation/<%= r.id %>/delete" class="d-inline" onsubmit="return confirm('Delete this sponsor confirmation form? This is helpful for removing test entries.');">
                    <button class="btn btn-sm btn-outline-danger" type="submit"><%= t('remove') %></button>
                  </form>
                <% } %>
              </td>
            </tr>
          <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>
  </div>

  <p class="footer-note"><%= t('footer_note') %></p>
</main>
</body>
</html>

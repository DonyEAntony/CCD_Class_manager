<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <main class="container py-4 app-shell">
    <div class="d-flex justify-content-end gap-2 mb-3">
      <span class="text-secondary"><%= t('language') %>:</span>
      <a href="/lang/en" class="btn btn-sm <%= lang === 'en' ? 'btn-primary' : 'btn-outline-primary' %>"><%= t('english') %></a>
      <a href="/lang/es" class="btn btn-sm <%= lang === 'es' ? 'btn-primary' : 'btn-outline-primary' %>"><%= t('spanish') %></a>
    </div>
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-2">
      <div>
        <h1 class="h3 mb-1"><%= t('dashboard') %></h1>
        <p class="text-secondary mb-0"><%= t('signed_in_as') %> <strong><%= user.email %></strong></p>
      </div>
      <div class="d-flex gap-2">
        <span class="badge text-bg-primary badge-role align-self-center"><%= user.role %></span>
        <a class="btn btn-primary" href="/registration/new"><%= t('new_registration') %></a>
        <a class="btn btn-info" href="/registration/adult"><%= t('register_adult') %></a>
        <% if (user.role === 'admin') { %><a class="btn btn-outline-primary" href="/admin/users"><%= t('manage_users') %></a><% } %>
        <a class="btn btn-outline-secondary" href="/logout"><%= t('logout') %></a>
      </div>
    </div>

    <% if (success.length) { %><div class="alert alert-success"><%= success[0] %></div><% } %>
    <% if (error.length) { %><div class="alert alert-danger"><%= error[0] %></div><% } %>

    <div class="card page-card">
      <div class="card-header p-3"><h2 class="h5 mb-0"><%= t('submitted_registrations') %></h2></div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0 align-middle">
            <thead>
              <tr><th><%= t('student') %></th><th><%= t('grade') %></th><th><%= t('primary_contact') %></th><th><%= t('total_fees') %></th><th><%= t('certificates') %></th></tr>
            </thead>
            <tbody>
            <% registrations.forEach(r => { %>
              <tr>
                <td><%= r.student_full_name %></td>
                <td><%= r.ccd_grade_level %></td>
                <td><%= r.parent_name || r.primary_contact_email || '-' %></td>
                <td>$<%= r.registration_fee + r.sacramental_fee + r.late_fee %></td>
                <td>
                  <% if (r.baptism_certificate_path) { %><a href="/<%= r.baptism_certificate_path %>"><%= t('baptism') %></a><% } %>
                  <% if (r.first_communion_certificate_path) { %> | <a href="/<%= r.first_communion_certificate_path %>"><%= t('communion') %></a><% } %>
                </td>
              </tr>
            <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <% if (adultRegistrations && adultRegistrations.length) { %>
    <div class="card page-card mt-3">
      <div class="card-header p-3"><h2 class="h5 mb-0">Adult Registrations</h2></div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0 align-middle">
            <thead>
              <tr><th>Name</th><th>Email</th><th>Phone</th><th>Event Type</th></tr>
            </thead>
            <tbody>
            <% adultRegistrations.forEach(r => { %>
              <tr>
                <td><%= r.full_name %></td>
                <td><%= r.email %></td>
                <td><%= r.phone %></td>
                <td><%= r.event_type %></td>
              </tr>
            <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
    <% } %>
  </main>
</body>
</html>

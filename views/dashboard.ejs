<!doctype html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard &mdash; St. Matthew CCD</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body>

<%- include('_topbar') %>

<main class="container py-4 app-shell mx-auto">

  <% if (success.length) { %><div class="alert alert-success mb-3"><%= success[0] %></div><% } %>
  <% if (error.length) { %><div class="alert alert-danger mb-3"><%= error[0] %></div><% } %>

  <!-- Page heading -->
  <div class="page-heading d-flex flex-wrap justify-content-between align-items-end gap-2">
    <div>
      <h1><%= t('dashboard') %></h1>
      <p class="sub mb-0"><%= t('signed_in_as') %> <strong><%= user.email %></strong>
        &ensp;<span class="badge badge-role badge-<%= user.role %>"><%= user.role %></span>
      </p>
    </div>
    <div class="d-flex flex-wrap gap-2">
      <a class="btn btn-primary" href="/registration/new"><%= t('new_registration') %></a>
      <a class="btn btn-outline-success" href="/registration/adult"><%= t('register_adult') %></a>
      <% if (user.role === 'admin') { %>
        <a class="btn btn-outline-primary" href="/admin/users"><%= t('manage_users') %></a>
      <% } %>
      <a class="btn btn-outline-secondary" href="/logout"><%= t('logout') %></a>
    </div>
  </div>

  <!-- Student registrations -->
  <div class="page-card">
    <div class="card-header">
      <h2 class="h5"><%= t('submitted_registrations') %></h2>
    </div>
    <div class="card-body p-0">
      <% if (registrations.length === 0) { %>
        <div class="p-4 text-center" style="color:var(--muted);font-size:.92rem">
          <em>No registrations yet. Use the button above to register a child.</em>
        </div>
      <% } else { %>
      <div class="table-responsive">
        <table class="table mb-0">
          <thead>
            <tr>
              <th><%= t('student') %></th>
              <th><%= t('grade') %></th>
              <th><%= t('primary_contact') %></th>
              <th><%= t('total_fees') %></th>
              <th><%= t('certificates') %></th>
            </tr>
          </thead>
          <tbody>
          <% registrations.forEach(r => { %>
            <tr>
              <td style="font-weight:600"><%= r.student_full_name %></td>
              <td><%= r.ccd_grade_level || '&mdash;' %></td>
              <td style="font-size:.85rem"><%= r.parent_name || r.primary_contact_email || '&mdash;' %></td>
              <td><strong>$<%= r.registration_fee + r.sacramental_fee + r.late_fee %></strong></td>
              <td style="font-size:.85rem">
                <% if (r.baptism_certificate_path) { %><a href="/<%= r.baptism_certificate_path %>"><%= t('baptism') %></a><% } %>
                <% if (r.baptism_certificate_path && r.first_communion_certificate_path) { %> &middot; <% } %>
                <% if (r.first_communion_certificate_path) { %><a href="/<%= r.first_communion_certificate_path %>"><%= t('communion') %></a><% } %>
                <% if (!r.baptism_certificate_path && !r.first_communion_certificate_path) { %><span style="color:var(--muted)">&mdash;</span><% } %>
              </td>
            </tr>
          <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>
  </div>

  <!-- Adult registrations -->
  <% if (adultRegistrations && adultRegistrations.length) { %>
  <div class="page-card mt-4">
    <div class="card-header">
      <h2 class="h5">Adult Faith Formation / OCIA Registrations</h2>
    </div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table mb-0">
          <thead>
            <tr><th>Name</th><th>Email</th><th>Phone</th><th>Event Type</th></tr>
          </thead>
          <tbody>
          <% adultRegistrations.forEach(r => { %>
            <tr>
              <td style="font-weight:600"><%= r.full_name %></td>
              <td style="font-size:.85rem"><%= r.email || '&mdash;' %></td>
              <td style="font-size:.85rem"><%= r.phone || '&mdash;' %></td>
              <td><span class="badge" style="background:var(--forest);color:#fff;font-size:.7rem;border-radius:2rem;padding:.3em .8em"><%= r.event_type %></span></td>
            </tr>
          <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <% } %>

  <p class="footer-note"><%= t('footer_note') %></p>
</main>
</body>
</html>

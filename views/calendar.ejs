<!doctype html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= t('calendar') %> &mdash; <%= t('app_title') %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Hedvig+Letters+Serif:opsz@12..24&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
<%- include('_topbar') %>
<main class="container py-4 app-shell mx-auto">

  <div class="page-heading d-flex flex-wrap justify-content-between align-items-end gap-2">
    <div>
      <h1><%= t('monthly_calendar') %></h1>
      <p class="sub mb-0"><%= calendarMonthLabel %></p>
    </div>
    <a class="btn btn-outline-secondary" href="/dashboard"><%= t('back_to_dashboard') %></a>
  </div>

  <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <a class="btn btn-outline-secondary" href="/calendar?month=<%= previousMonthParam %>"><%= t('previous_month') %></a>
    <a class="btn btn-outline-secondary" href="/calendar?month=<%= nextMonthParam %>"><%= t('next_month') %></a>
  </div>

  <div class="page-card">
    <div class="card-body">
      <% if (!monthEvents.length) { %>
        <div class="alert alert-secondary mb-0"><%= t('no_events_this_month') %></div>
      <% } else { %>
        <div class="calendar-grid">
          <% weekdayLabels.forEach((weekday) => { %>
            <div class="calendar-weekday"><%= weekday %></div>
          <% }) %>
          <% weeks.forEach((week) => { %>
            <% week.forEach((day) => { %>
              <div class="calendar-cell <%= day.dayNumber ? '' : 'calendar-cell-empty' %>">
                <% if (day.dayNumber) { %>
                  <div class="calendar-day-number"><%= day.dayNumber %></div>
                  <div class="calendar-events">
                    <% day.events.forEach((eventItem) => { %>
                      <div class="calendar-event-pill">
                        <strong><%= eventItem.title %></strong>
                        <span>
                          <% if (eventItem.schedule_type === 'recurring' && eventItem.recurrence_pattern) { %><%= eventItem.recurrence_pattern %><% } %>
                          <% if (eventItem.event_time) { %><%= eventItem.schedule_type === 'recurring' && eventItem.recurrence_pattern ? ' · ' : '' %><%= eventItem.event_time %><% } %>
                          <% if (eventItem.event_end_time) { %> - <%= eventItem.event_end_time %><% } %>
                          <% if (eventItem.location) { %> · <%= eventItem.location %><% } %>
                        </span>
                      </div>
                    <% }) %>
                  </div>
                <% } %>
              </div>
            <% }) %>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>

  <p class="footer-note"><%= t('footer_note') %></p>
</main>
</body>
</html>

<!doctype html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= t('mass_serving_signup_title') %> &mdash; <%= t('app_title') %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
  <style>
    .mass-hero {
      background:
        radial-gradient(circle at top right, rgba(232, 184, 75, 0.22), transparent 32%),
        linear-gradient(135deg, var(--navy) 0%, #214067 56%, #496e98 100%);
      color: #fff;
      border-radius: 18px;
      padding: 2rem;
      overflow: hidden;
    }
    .role-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 0.9rem;
    }
    .role-card {
      border: 1px solid var(--border);
      border-radius: 12px;
      background: var(--white);
      padding: 0.95rem 1rem;
      transition: border-color 0.18s, box-shadow 0.18s, transform 0.18s;
    }
    .role-card:has(input:checked) {
      border-color: var(--blue-sky);
      box-shadow: 0 8px 24px var(--shadow-md);
      transform: translateY(-1px);
    }
    .role-card.is-taken {
      background: #f7f1ea;
      border-color: #e5c8a5;
      opacity: 0.78;
    }
    .role-card.is-taken input {
      pointer-events: none;
    }
    .role-meta {
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.09em;
      color: var(--muted);
      font-weight: 700;
      margin-bottom: 0.35rem;
    }
    .slot-board {
      background: var(--off-white);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 1rem;
    }
    .mass-list-card {
      border: 1px solid var(--border);
      border-radius: 12px;
      background: var(--white);
      padding: 0.95rem 1rem;
    }
  </style>
</head>
<body>
<%- include('_topbar') %>
<main class="container py-4 app-shell mx-auto">
  <% if (success.length) { %><div class="alert alert-success mb-3"><%= success[0] %></div><% } %>
  <% if (error.length) { %><div class="alert alert-danger mb-3"><%= error[0] %></div><% } %>

  <section class="mass-hero mb-4">
    <p style="text-transform:uppercase;letter-spacing:.14em;font-size:.72rem;font-weight:700;color:rgba(255,255,255,.72)">CCD Ministry</p>
    <h1 style="color:#fff;margin-bottom:.6rem"><%= t('mass_serving_signup_title') %></h1>
    <p style="max-width:720px;color:rgba(255,255,255,.84)">Choose a Mass first, then pick from the roles the parish has opened for that service.</p>
  </section>

  <div class="row g-4">
    <div class="col-lg-7">
      <div class="page-card">
        <div class="card-header"><h2 class="h5 mb-0">Sign Up a Child</h2></div>
        <div class="card-body">
          <% if (!masses || masses.length === 0) { %>
            <div class="alert alert-secondary mb-0">No Masses are open for signup right now. Please check back after the parish office publishes a Mass.</div>
          <% } else { %>
            <form class="row g-3" method="post" action="/mass-serving-signup">
              <div class="col-md-8">
                <label class="form-label required">Student Name</label>
                <input class="form-control" type="text" name="student_name" list="student-options" required>
                <datalist id="student-options">
                  <% studentOptions.forEach((student) => { %>
                    <option value="<%= student.student_full_name %>"><%= student.ccd_grade_level || '' %></option>
                  <% }) %>
                </datalist>
              </div>
              <div class="col-md-4">
                <label class="form-label">CCD Grade</label>
                <input class="form-control" type="text" name="ccd_grade_level" placeholder="Example: 4th Grade">
              </div>
              <div class="col-md-6">
                <label class="form-label required">Mass</label>
                <select class="form-select" name="mass_id" id="mass-id" required>
                  <option value="">Select a Mass</option>
                  <% masses.forEach((mass) => { %>
                    <option value="<%= mass.id %>"><%= mass.titleLabel %></option>
                  <% }) %>
                </select>
              </div>
              <div class="col-md-6">
                <label class="form-label">Parent / Guardian</label>
                <input class="form-control" type="text" name="parent_name" value="<%= user.full_name || '' %>">
              </div>
              <div class="col-md-6">
                <label class="form-label">Contact Email</label>
                <input class="form-control" type="email" name="contact_email" value="<%= user.email || '' %>">
              </div>
              <div class="col-md-6">
                <label class="form-label">Contact Phone</label>
                <input class="form-control" type="tel" name="contact_phone" value="<%= user.phone || '' %>" pattern="[0-9]{3}[.\- ]?[0-9]{3}[.\- ]?[0-9]{4}" title="Format: 123-456-7890 or 123.456.7890 or 123 456 7890">
              </div>
              <div class="col-12">
                <label class="form-label required">Available Roles</label>
                <div class="role-grid" id="role-grid">
                  <% massServingRoleOptions.forEach((option) => { %>
                    <label class="role-card d-none" data-role-code="<%= option.value %>">
                      <div class="form-check mb-0">
                        <input class="form-check-input" type="checkbox" name="role_codes" value="<%= option.value %>" id="role-<%= option.value %>">
                        <div class="ms-4">
                          <div class="role-meta"><%= option.section %></div>
                          <div style="font-weight:700;color:var(--navy)"><%= option.label %></div>
                          <div class="small text-muted role-status">Select a Mass first.</div>
                        </div>
                      </div>
                    </label>
                  <% }) %>
                </div>
              </div>
              <div class="col-12">
                <label class="form-label">Notes</label>
                <textarea class="form-control" name="notes" rows="4" placeholder="Optional note for the parish office"></textarea>
              </div>
              <div class="col-12 d-flex flex-wrap gap-2">
                <button class="btn btn-primary" type="submit">Submit Signup</button>
                <a class="btn btn-outline-secondary" href="/dashboard"><%= t('back_to_dashboard') %></a>
              </div>
            </form>
          <% } %>
        </div>
      </div>
    </div>

    <div class="col-lg-5">
      <div class="slot-board mb-3">
        <div style="font-size:.72rem;text-transform:uppercase;letter-spacing:.1em;font-weight:700;color:var(--muted);margin-bottom:.55rem">Service Sheet Preview</div>
        <h2 class="h5 mb-2" id="board-title">Select a Mass</h2>
        <p class="small text-muted mb-0" id="board-notes">Only the roles opened by the parish office appear here.</p>
      </div>
      <div class="page-card mb-4">
        <div class="card-header"><h2 class="h5 mb-0">Masses Open for Signup</h2></div>
        <div class="card-body d-flex flex-column gap-2">
          <% if (!masses || masses.length === 0) { %>
            <div class="text-muted">No Masses have been published yet.</div>
          <% } else { %>
            <% masses.forEach((mass) => { %>
              <div class="mass-list-card">
                <div style="font-weight:700;color:var(--navy)"><%= mass.title || 'Mass Signup' %></div>
                <div class="small text-muted mb-1"><%= mass.massLabel %></div>
                <div class="small"><%= mass.availableRoles.map((role) => role.label).join(', ') %></div>
              </div>
            <% }) %>
          <% } %>
        </div>
      </div>
      <div class="page-card">
        <div class="card-header"><h2 class="h5 mb-0">Role Availability</h2></div>
        <div class="card-body">
          <div id="slot-board-lines" class="d-flex flex-column gap-2">
            <div class="text-muted">Select a Mass to view its signup roles.</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</main>
<script>
  (function () {
    const masses = <%- JSON.stringify(masses) %>;
    const existingSignups = <%- JSON.stringify(existingSignups) %>;
    const massSelect = document.getElementById('mass-id');
    const boardTitle = document.getElementById('board-title');
    const boardNotes = document.getElementById('board-notes');
    const roleCards = Array.from(document.querySelectorAll('[data-role-code]'));
    const slotBoard = document.getElementById('slot-board-lines');
    const signupMap = existingSignups.reduce((acc, signup) => {
      const key = String(signup.mass_id || '');
      if (!acc[key]) acc[key] = new Set();
      acc[key].add(signup.role_code);
      return acc;
    }, {});
    const massMap = masses.reduce((acc, mass) => {
      acc[String(mass.id)] = mass;
      return acc;
    }, {});

    const renderMass = () => {
      const mass = massMap[massSelect?.value || ''];
      roleCards.forEach((card) => {
        const roleCode = card.getAttribute('data-role-code');
        const input = card.querySelector('input[type="checkbox"]');
        const status = card.querySelector('.role-status');

        if (!mass) {
          card.classList.add('d-none');
          card.classList.remove('is-taken');
          input.checked = false;
          input.disabled = true;
          status.textContent = 'Select a Mass first.';
          return;
        }

        const massRoleCodes = new Set((mass.availableRoleCodes || []).map(String));
        const visible = massRoleCodes.has(roleCode);
        const takenRoles = signupMap[String(mass.id)] || new Set();
        const taken = takenRoles.has(roleCode);

        card.classList.toggle('d-none', !visible);
        if (!visible) {
          input.checked = false;
          input.disabled = true;
          return;
        }

        input.disabled = taken;
        if (taken) input.checked = false;
        card.classList.toggle('is-taken', taken);
        status.textContent = taken ? 'Already taken for this Mass.' : 'Available for this Mass.';
      });

      if (!mass) {
        boardTitle.textContent = 'Select a Mass';
        boardNotes.textContent = 'Only the roles opened by the parish office appear here.';
        slotBoard.innerHTML = '<div class="text-muted">Select a Mass to view its signup roles.</div>';
        return;
      }

      boardTitle.textContent = mass.titleLabel;
      boardNotes.textContent = mass.notes || 'Only the roles opened for this Mass can be selected.';

      const takenRoles = signupMap[String(mass.id)] || new Set();
      slotBoard.innerHTML = (mass.availableRoles || []).map((role) => `
        <div style="border:1px solid var(--border);border-radius:10px;padding:.75rem .9rem;background:var(--off-white);display:flex;justify-content:space-between;gap:1rem">
          <div>
            <div style="font-weight:700;color:var(--navy)">${role.label}</div>
            <div class="small text-muted">${role.section || ''}</div>
          </div>
          <div style="font-weight:700;color:${takenRoles.has(role.value) ? '#8a5b1f' : 'var(--forest)'}">
            ${takenRoles.has(role.value) ? 'Taken' : 'Available'}
          </div>
        </div>
      `).join('');
    };

    if (massSelect) {
      massSelect.addEventListener('change', renderMass);
      renderMass();
    }
  }());
</script>
</body>
</html>

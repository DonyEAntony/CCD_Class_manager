<!doctype html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Adult Registration &mdash; St. Matthew CCD</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,400&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body>

<%- include('_topbar') %>

<main class="container py-4 app-shell mx-auto">

  <div class="page-heading d-flex flex-wrap justify-content-between align-items-end gap-2">
    <div>
      <h1><%= t('adult_registration_form_title') %></h1>
      <p class="sub mb-0"><%= t('app_title') %> &mdash; <%= t('school_year') %></p>
    </div>
    <a class="btn btn-outline-secondary" href="/dashboard"><%= t('back') %></a>
  </div>

  <div class="page-card">
    <div class="card-body p-4">
      <form method="post" action="/registration/adult" class="row g-3">
        <div class="col-md-6">
          <label class="form-label"><%= t('full_name') %></label>
          <input class="form-control" type="text" name="full_name" required>
        </div>
        <div class="col-md-6">
          <label class="form-label"><%= t('email') %></label>
          <input class="form-control" type="email" name="email">
        </div>
        <div class="col-md-6">
          <label class="form-label"><%= t('phone') %></label>
          <input class="form-control" type="text" name="phone">
        </div>
        <div class="col-md-6">
          <label class="form-label"><%= t('event_type') %></label>
          <select class="form-select" name="event_type" required>
            <option value="OCIA"><%= t('ocio') %></option>
            <option value="Other"><%= t('other_adult') %></option>
          </select>
        </div>
        <div class="col-12">
          <label class="form-label"><%= t('comments') %></label>
          <textarea class="form-control" rows="4" name="comments"></textarea>
        </div>
        <div class="col-12 d-flex gap-2">
          <button class="btn btn-primary" type="submit"><%= t('submit_registration') %></button>
          <a class="btn btn-outline-secondary" href="/dashboard"><%= t('cancel') %></a>
        </div>
      </form>
    </div>
  </div>

  <p class="footer-note"><%= t('footer_note') %></p>
</main>
</body>
</html>

<!doctype html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= program.title %> &mdash; <%= t('app_title') %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Hedvig+Letters+Serif:opsz@12..24&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
<%- include('_topbar') %>
<main class="container py-4 app-shell mx-auto">
  <% const visibleEvents = Array.isArray(typeof relevantEvents === 'undefined' ? null : relevantEvents) ? relevantEvents : []; %>

  <div class="page-heading d-flex flex-wrap justify-content-between align-items-end gap-2">
    <div>
      <h1><%= program.title %></h1>
      <p class="sub mb-0"><%= program.subtitle %> &mdash; <%= t('app_title') %></p>
    </div>
    <a class="btn btn-outline-secondary" href="/dashboard"><%= t('back') %></a>
  </div>

  <div class="alert alert-secondary mb-4" style="border-left:3px solid var(--blue-sky);border-radius:6px;font-size:.9rem">
    <%= program.description %>
  </div>

  <div class="page-card">
    <% if (error && error.length) { %><div class="alert alert-danger mb-3"><%= error[0] %></div><% } %>
    <% if (success && success.length) { %><div class="alert alert-success mb-3"><%= success[0] %></div><% } %>
    <% if (visibleEvents.length) { %>
      <div class="alert alert-info mb-3">
        <strong><%= t('faith_formation_events') %>:</strong>
        <ul class="mb-0 mt-2 ps-3">
          <% visibleEvents.forEach((eventItem) => { %>
            <li>
              <strong><%= eventItem.title %></strong>
              <% if (eventItem.schedule_type === 'recurring' && eventItem.recurrence_pattern) { %> · <%= eventItem.recurrence_pattern %><% } %>
              <% if (eventItem.event_date) { %> · <%= eventItem.event_date %><% } %>
              <% if (eventItem.event_time) { %> · <%= eventItem.event_time %><% } %>
              <% if (eventItem.event_end_time) { %> - <%= eventItem.event_end_time %><% } %>
              <% if (eventItem.location) { %> · <%= eventItem.location %><% } %>
            </li>
          <% }) %>
        </ul>
      </div>
    <% } %>
    <div class="card-body p-4">
      <form method="post" action="/registration/adult/<%= program.key %>" class="row g-3">
        <input type="hidden" name="registration_id" value="<%= reg ? reg.id : '' %>">

        <!-- Core fields — all programs -->
        <fieldset class="col-12">
          <legend><%= t('your_information') %></legend>
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label"><%= t('full_name') %> <span class="text-danger">*</span></label>
              <input class="form-control" type="text" name="full_name" required>
            </div>
            <div class="col-md-6">
              <label class="form-label"><%= t('email') %></label>
              <input class="form-control" type="email" name="email">
              <div class="invalid-feedback">Please enter a valid email address.</div>
            </div>
            <div class="col-md-4">
              <label class="form-label"><%= t('phone') %></label>
              <input class="form-control" type="tel" name="phone" pattern="[0-9]{3}[.\- ]?[0-9]{3}[.\- ]?[0-9]{4}" title="Format: 123-456-7890 or 123.456.7890 or 123 456 7890">
              <div class="invalid-feedback">Please enter a valid phone number (XXX-XXX-XXXX format).</div>
            </div>
            <div class="col-md-4">
              <label class="form-label"><%= t('dob') %></label>
              <input class="form-control" type="date" name="dob">
            </div>
            <div class="col-md-4">
              <label class="form-label"><%= t('are_you_baptized') %></label>
              <select class="form-select" name="baptized">
                <option value=""><%= t('select_placeholder') %></option>
                <option value="yes_catholic"><%= t('baptized_yes_catholic') %></option>
                <option value="yes_other"><%= t('baptized_yes_other') %></option>
                <option value="no"><%= t('baptized_no') %></option>
                <option value="unsure"><%= t('baptized_unsure') %></option>
              </select>
            </div>
          </div>
        </fieldset>

        <!-- Address -->
        <fieldset class="col-12">
          <legend><%= t('address_information') %></legend>
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label"><%= t('address') %></label>
              <input class="form-control" type="text" name="address">
            </div>
            <div class="col-md-4">
              <label class="form-label"><%= t('city') %></label>
              <input class="form-control" type="text" name="city">
            </div>
            <div class="col-md-4">
              <label class="form-label"><%= t('state') %></label>
              <input class="form-control" type="text" name="state">
            </div>
            <div class="col-md-4">
              <label class="form-label"><%= t('zip') %></label>
              <input class="form-control" type="text" name="zip">
            </div>
          </div>
        </fieldset>

        <!-- Baptism Prep extras -->
        <% if (program.key === 'baptism_prep') { %>
        <fieldset class="col-12">
          <legend><%= t('baptism_details') %></legend>
          <% const availableBaptismPrepSchedules = Array.isArray(typeof baptismPrepSchedules === 'undefined' ? null : baptismPrepSchedules) ? baptismPrepSchedules : []; %>
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label"><%= t('class_date') %></label>
              <select class="form-select" name="class_schedule_id" required>
                <option value="" <%= !reg || !reg.class_schedule_id ? 'selected' : '' %> disabled><%= t('choose_class_date') %></option>
                <% availableBaptismPrepSchedules.forEach((scheduleOption) => { %>
                  <option value="<%= scheduleOption.id %>" <%= reg && String(reg.class_schedule_id || '') === String(scheduleOption.id) ? 'selected' : '' %>>
                    <%= scheduleOption.title %>
                    <% if (scheduleOption.schedule_type === 'recurring' && scheduleOption.recurrence_pattern) { %> · <%= scheduleOption.recurrence_pattern %><% } %>
                    <% if (scheduleOption.event_date) { %> · <%= scheduleOption.event_date %><% } %>
                    <% if (scheduleOption.event_time) { %> · <%= scheduleOption.event_time %><% } %>
                    <% if (scheduleOption.event_end_time) { %> - <%= scheduleOption.event_end_time %><% } %>
                    <% if (scheduleOption.location) { %> · <%= scheduleOption.location %><% } %>
                  </option>
                <% }) %>
              </select>
              <% if (!availableBaptismPrepSchedules.length) { %>
                <div class="form-text text-muted"><%= t('no_class_dates_available') %></div>
              <% } %>
            </div>
            <div class="col-md-6">
              <label class="form-label"><%= t('name_of_person_baptized') %></label>
              <input class="form-control" type="text" name="godparent_for">
            </div>
            <div class="col-md-6">
              <label class="form-label"><%= t('your_role') %></label>
              <select class="form-select" name="baptism_role">
                <option value="parent"><%= t('role_parent') %></option>
                <option value="godparent"><%= t('role_godparent') %></option>
                <option value="both"><%= t('role_both') %></option>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">
                <%= t('spouse_coparent_name') %>
                <span style="font-weight:400;font-size:.78rem;color:var(--muted)"><%= t('if_attending_together') %></span>
              </label>
              <input class="form-control" type="text" name="spouse_name">
            </div>
          </div>
        </fieldset>
        <% } %>

        <!-- Adult Confirmation extras -->
        <% if (program.key === 'adult_confirmation') { %>
        <fieldset class="col-12">
          <legend><%= t('sacramental_history') %></legend>
          <div class="row g-3">
            <div class="col-md-8">
              <label class="form-label"><%= t('church_where_baptized') %></label>
              <input class="form-control" type="text" name="baptism_church" placeholder="<%= t('church_placeholder') %>">
            </div>
            <div class="col-md-4">
              <label class="form-label">
                <%= t('baptism_date_approx') %>
                <span style="font-weight:400;font-size:.78rem;color:var(--muted)"><%= t('approx_ok') %></span>
              </label>
              <input class="form-control" type="date" name="baptism_date_conf">
            </div>
            <div class="col-md-6">
              <label class="form-label"><%= t('received_first_communion') %></label>
              <select class="form-select" name="received_communion">
                <option value="yes"><%= t('yes') %></option>
                <option value="no"><%= t('no') %></option>
              </select>
            </div>
          </div>
        </fieldset>
        <% } %>

        <!-- Comments -->
        <div class="col-12">
          <label class="form-label"><%= t('questions_comments') %></label>
          <textarea class="form-control" rows="3" name="comments" placeholder="<%= t('comments_placeholder') %>"></textarea>
        </div>

        <div class="col-12 d-flex gap-2 pt-1">
          <button class="btn btn-secondary" type="button" id="save-draft"><%= t('save_draft') %></button>
          <button class="btn btn-primary" type="submit"><%= t('submit_registration') %></button>
          <a class="btn btn-outline-secondary" href="/dashboard"><%= t('cancel') %></a>
        </div>

      </form>
    </div>
  </div>

  <p class="footer-note"><%= t('footer_note') %></p>
</main>

<script>
  // Save draft functionality
  (function () {
    const form = document.querySelector('form');
    const saveBtn = document.getElementById('save-draft');

    function saveFormData() {
      const formData = new FormData(form);
      const data = {};
      for (let [key, value] of formData.entries()) {
        if (data[key]) {
          if (Array.isArray(data[key])) {
            data[key].push(value);
          } else {
            data[key] = [data[key], value];
          }
        } else {
          data[key] = value;
        }
      }
      localStorage.setItem('adult-registration-draft', JSON.stringify(data));
      alert('Draft saved!');
    }

    function loadFormData() {
      const data = localStorage.getItem('adult-registration-draft');
      if (data) {
        const parsed = JSON.parse(data);
        for (let key in parsed) {
          const elements = form.querySelectorAll(`[name="${key}"]`);
          if (elements.length > 1) {
            // Array inputs
            parsed[key].forEach((value, index) => {
              if (elements[index]) {
                if (elements[index].type === 'file') return; // Skip file inputs
                if (elements[index].type === 'checkbox' || elements[index].type === 'radio') {
                  elements[index].checked = value;
                } else {
                  elements[index].value = value;
                }
              }
            });
          } else if (elements[0]) {
            if (elements[0].type === 'file') continue; // Skip file inputs
            if (elements[0].type === 'checkbox' || elements[0].type === 'radio') {
              elements[0].checked = parsed[key];
            } else {
              elements[0].value = parsed[key];
            }
          }
        }
      }
    }

    saveBtn.addEventListener('click', saveFormData);
    loadFormData();

    // Enable submit only if required fields are filled and valid
    const submitBtn = document.querySelector('button[type="submit"]');
    const validationForm = document.querySelector('form');
    const emailInput = validationForm.querySelector('[name="email"]');
    const phoneInput = validationForm.querySelector('[name="phone"]');
    function checkRequired() {
      const name = validationForm.querySelector('[name="full_name"]').value.trim();
      const email = emailInput.value.trim();
      const phone = phoneInput.value.trim();

      // Email validation
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      const emailValid = !email || emailRegex.test(email); // Optional, but if provided, must be valid

      // Phone validation (allows XXX-XXX-XXXX, XXX.XXX.XXXX, XXX XXX XXXX)
      const phoneRegex = /^\d{3}[-.\s]?\d{3}[-.\s]?\d{4}$/;
      const phoneValid = !phone || phoneRegex.test(phone); // Optional

      // Visual feedback
      if (email) {
        emailInput.classList.toggle('is-invalid', !emailValid);
        emailInput.classList.toggle('is-valid', emailValid);
      } else {
        emailInput.classList.remove('is-invalid', 'is-valid');
      }
      if (phone) {
        phoneInput.classList.toggle('is-invalid', !phoneValid);
        phoneInput.classList.toggle('is-valid', phoneValid);
      } else {
        phoneInput.classList.remove('is-invalid', 'is-valid');
      }

      // Add was-validated if any invalid
      const hasInvalid = (email && !emailValid) || (phone && !phoneValid);
      validationForm.classList.toggle('was-validated', hasInvalid);

      const contactValid = emailValid && phoneValid && (email || phone);
      submitBtn.disabled = !(name && contactValid);
    }
    validationForm.addEventListener('input', checkRequired);
    validationForm.addEventListener('change', checkRequired);
    validationForm.addEventListener('submit', (e) => {
      const name = validationForm.querySelector('[name="full_name"]').value.trim();
      const email = emailInput.value.trim();
      const phone = phoneInput.value.trim();
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      const phoneRegex = /^\d{3}[-.\s]?\d{3}[-.\s]?\d{4}$/;
      const emailValid = !email || emailRegex.test(email);
      const phoneValid = !phone || phoneRegex.test(phone);
      const contactValid = emailValid && phoneValid && (email || phone);
      if (!name || !contactValid) {
        e.preventDefault();
        alert('Please correct the validation errors before submitting.');
      }
    });
    checkRequired(); // Initial check
  }());
</script>
</body>
</html>

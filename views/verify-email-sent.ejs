<!doctype html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Verify Email &mdash; <%= t('app_title') %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
<%- include('_topbar') %>
<main class="container py-5 app-shell mx-auto">
  <div class="row justify-content-center">
    <div class="col-md-10 col-lg-7">
      <div class="page-card">
        <div class="card-body p-4">
          <h1 style="font-family:'Playfair Display',Georgia,serif;font-size:2rem;margin-bottom:1rem">Verify your email</h1>
          <p class="mb-3">Your account has been created but is not active yet. Open the verification link sent to <strong><%= email %></strong> to activate it.</p>

          <% if (!emailDeliveryConfigured && verificationPreviewUrl) { %>
            <div class="alert alert-warning">
              Email delivery is not configured in this environment. Use the development verification link below.
            </div>
            <p class="mb-3">
              <a class="btn btn-primary" href="<%= verificationPreviewUrl %>">Activate this test account</a>
            </p>
          <% } %>

          <div class="d-flex gap-2">
            <a class="btn btn-outline-secondary" href="/login">Back to login</a>
            <a class="btn btn-outline-primary" href="/signup">Create another account</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</main>
</body>
</html>

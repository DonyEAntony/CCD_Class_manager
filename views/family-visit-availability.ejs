<!doctype html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= t('manage_visit_availability') %> &mdash; <%= t('app_title') %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
<%- include('_topbar') %>
<main class="container py-4 app-shell mx-auto">
  <% const availableLeaders = Array.isArray(typeof leaders === 'undefined' ? null : leaders) ? leaders : []; %>
  <% const configuredVisitSlots = Array.isArray(typeof visitSlots === 'undefined' ? null : visitSlots) ? visitSlots : []; %>

  <% if (success.length) { %><div class="alert alert-success mb-3"><%= success[0] %></div><% } %>
  <% if (error.length) { %><div class="alert alert-danger mb-3"><%= error[0] %></div><% } %>

  <div class="page-heading d-flex flex-wrap justify-content-between align-items-end gap-2">
    <div>
      <h1><%= t('manage_visit_availability') %></h1>
      <p class="sub mb-0"><%= isAdmin ? t('family_faith_leader') : t('your_visit_availability') %></p>
    </div>
    <a class="btn btn-outline-secondary" href="/dashboard"><%= t('back_to_dashboard') %></a>
  </div>

  <div class="page-card mb-4">
    <div class="card-header"><h2 class="h5"><%= t('add_visit_slots') %></h2></div>
    <div class="card-body">
      <form method="post" action="/family-faith/visits/availability" class="row g-3 align-items-end">
        <% if (isAdmin) { %>
          <div class="col-md-4">
            <label class="form-label"><%= t('leader') %></label>
            <select class="form-select" name="leader_user_id" required>
              <option value="">Select leader</option>
              <% availableLeaders.forEach((leader) => { %>
                <option value="<%= leader.id %>" <%= Number(selectedLeaderId) === Number(leader.id) ? 'selected' : '' %>><%= leader.full_name || leader.email %> (<%= leader.email %>)</option>
              <% }) %>
            </select>
          </div>
        <% } %>
        <div class="col-md-3">
          <label class="form-label"><%= t('visit_date') %></label>
          <input class="form-control" type="date" name="visit_date" required>
        </div>
        <div class="col-md-2">
          <label class="form-label"><%= t('start_time') %></label>
          <input class="form-control" type="time" name="start_time" step="1800" required>
        </div>
        <div class="col-md-2">
          <label class="form-label"><%= t('end_time') %></label>
          <input class="form-control" type="time" name="end_time" step="1800" required>
        </div>
        <div class="col-md-2">
          <button class="btn btn-primary" type="submit"><%= t('save') %></button>
        </div>
      </form>
    </div>
  </div>

  <div class="page-card">
    <div class="card-header"><h2 class="h5"><%= t('configured_visit_slots') %></h2></div>
    <div class="card-body p-0">
      <% if (!configuredVisitSlots.length) { %>
        <div class="p-4 text-muted"><%= t('no_visit_slots_configured') %></div>
      <% } else { %>
        <div class="table-responsive">
          <table class="table mb-0">
            <thead>
              <tr>
                <% if (isAdmin) { %><th><%= t('leader') %></th><% } %>
                <th><%= t('visit_date') %></th>
                <th><%= t('visit_window') %></th>
                <th>Status</th>
                <th><%= t('actions') %></th>
              </tr>
            </thead>
            <tbody>
              <% configuredVisitSlots.forEach((slot) => { %>
                <% const start = new Date(slot.slot_start); %>
                <% const end = new Date(slot.slot_end); %>
                <tr>
                  <% if (isAdmin) { %><td><%= slot.leader_name || slot.leader_email %></td><% } %>
                  <td><%= start.toISOString().slice(0, 10) %></td>
                  <td><%= start.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' }) %> - <%= end.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' }) %></td>
                  <td>
                    <% if (slot.booked_registration_id) { %>
                      <span class="badge text-bg-success"><%= t('visit') %> booked</span>
                      <div style="font-size:.82rem;color:var(--muted)"><%= slot.family_name || slot.primary_contact_name || '' %></div>
                    <% } else { %>
                      <span class="badge text-bg-light">Open</span>
                    <% } %>
                  </td>
                  <td>
                    <form method="post" action="/family-faith/visits/availability/<%= slot.id %>/delete" onsubmit="return confirm('Remove this Visit slot?');">
                      <button class="btn btn-outline-danger btn-sm" type="submit" <%= slot.booked_registration_id ? 'disabled' : '' %>><%= t('remove') %></button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>
</main>
</body>
</html>
